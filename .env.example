CHANNEL=miantiao_me

LOCALE=zh-CN
TIMEZONE=Asia/Shanghai

TELEGRAM=miantiao_me
TWITTER=miantiao_me
GITHUB=miantiao-me
DISCORD=https://DISCORD.com
PODCAST=https://PODCAST.com
MASTODON=mastodon.social/@Mastodon
BLUESKY=bsky.app

FOOTER_INJECT=
# Base is always loaded. Optionally load one trusted-admin override; never combine themes.
# See THEMES.md for every built-in path, platform values, custom CSS, and security notes.
# HEADER_INJECT='<link rel="stylesheet" href="/themes/aria.css">'
HEADER_INJECT=

NOFOLLOW=false
NOINDEX=false
HIDE_DESCRIPTION=false

TELEGRAM_HOST=telegram.dog
STATIC_PROXY=""
# Adapter selection is automatic. EdgeOne is detected through std-env's edgeone_pages
# provider or platform-provided EDGEONE_PROJECT_ID/EO_MAKERS. Override only when needed.
SERVER_ADAPTER=""
# Append hostname-only proxy targets to the default whitelist, separated by commas.
TARGET_WHITELIST=""
GOOGLE_SEARCH_SITE=""
TAGS=""
COMMENTS=""
REACTIONS=""
LINKS=""
NAVS=""
RSS_BEAUTIFY=""
# Display text content above media resources (images, videos, etc.) in posts.
TEXT_FIRST=false
# Show health info (heart rate and location) widget on the home page.
HEALTH_INFO=false
# OG link card prefetch (default: true). When enabled, link previews are
# asynchronously enriched with OpenGraph metadata (title, description, image).
# First visit shows a degraded preview; subsequent visits within 24h show the full card.
OG_PREVIEW=true
